# Database
DATABASE_URL=postgresql://sompheas:sompheas_dev@localhost:5434/sompheas

# Redis
REDIS_URL=redis://localhost:6381/0

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# LiveKit
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_URL=https://your-livekit-instance.livekit.cloud
LIVEKIT_WS_URL=wss://your-livekit-instance.livekit.cloud

# File Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Sandbox
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT=128m
SANDBOX_CPU_LIMIT=0.5

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO